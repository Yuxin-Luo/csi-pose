firmware/*/sdkconfig
firmware/*/sdkconfig.old
firmware/*/dependencies.lock
firmware/*/managed_components/

# 로컬 환경 전용 설정 — configs/*.example.yaml 을 복사해 작성
configs/boards.yaml
configs/train.yaml
configs/pairing.json

